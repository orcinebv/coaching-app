{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "module": "Node16",
    "moduleResolution": "Node16",
    "types": ["jest", "node"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "useDefineForClassFields": false,
    "isolatedModules": true,
    "target": "ES2022"
  },
  "include": [
    "jest.config.ts",
    "src/**/*.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ]
}
