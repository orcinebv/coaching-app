{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "module": "commonjs",
    "types": ["jest", "node"],
    "emitDecoratorMetadata": true,
    "esModuleInterop": true
  },
  "include": [
    "jest.config.ts",
    "src/**/*.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ]
}
