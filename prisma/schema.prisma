generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  COACH
  ADMIN
}

model Organization {
  id          String             @id @default(uuid())
  name        String
  slug        String             @unique
  plan        String             @default("free")
  maxUsers    Int                @default(10)
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  members     OrganizationUser[]
  auditLogs   AuditLog[]

  @@index([slug])
}

model OrganizationUser {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  coachId        String?
  joinedAt       DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation("OrgMembers", fields: [userId], references: [id], onDelete: Cascade)
  coach          User?        @relation("CoachRelation", fields: [coachId], references: [id])

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([coachId])
}

model AuditLog {
  id             String        @id @default(uuid())
  userId         String
  organizationId String?
  action         String
  resource       String
  resourceId     String?
  oldValue       String?
  newValue       String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@index([resource])
  @@index([createdAt])
}

model CoachNote {
  id         String   @id @default(uuid())
  coachId    String
  coacheeId  String
  content    String
  isPrivate  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  coach      User     @relation("CoachNotes", fields: [coachId], references: [id], onDelete: Cascade)
  coachee    User     @relation("CoacheeNotes", fields: [coacheeId], references: [id], onDelete: Cascade)

  @@index([coachId])
  @@index([coacheeId])
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  password            String
  name                String
  role                Role                 @default(USER)
  avatar              String?
  isActive            Boolean              @default(true)
  isOnboarded         Boolean              @default(false)
  deletedAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  conversations       Conversation[]
  checkIns            CheckIn[]
  settings            Settings?
  sessions            Session[]
  coachingSettings    CoachingSettings?
  goals               Goal[]
  journalEntries      JournalEntry[]
  exerciseCompletions ExerciseCompletion[]
  reports             Report[]
  sentimentResults    SentimentResult[]
  insights            UserInsight[]
  dailyPrompts        DailyPrompt[]
  recommendations     Recommendation[]
  aiUsage             AiUsage[]
  auditLogs           AuditLog[]
  organizations       OrganizationUser[]   @relation("OrgMembers")
  coachedUsers        OrganizationUser[]   @relation("CoachRelation")
  coachNotes          CoachNote[]          @relation("CoachNotes")
  coacheeNotes        CoachNote[]          @relation("CoacheeNotes")
}

model Conversation {
  id        String    @id @default(uuid())
  title     String
  userId    String
  status    String    @default("active")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id])
  messages  Message[]
}

model Message {
  id             String       @id @default(uuid())
  content        String
  role           String
  conversationId String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model CheckIn {
  id              String   @id @default(uuid())
  userId          String
  mood            Int
  energy          Int
  notes           String?
  goals           String?
  sleepHours      Float?
  sleepQuality    Int?
  waterGlasses    Int?
  activityMinutes Int?
  stressLevel     Int?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
}

model Settings {
  id            String  @id @default(uuid())
  userId        String  @unique
  notifications Boolean @default(true)
  theme         String  @default("light")
  language      String  @default("nl")
  checkInTime   String  @default("09:00")
  user          User    @relation(fields: [userId], references: [id])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([token])
}

model N8nData {
  id             String   @id @default(uuid())
  workflowId     String
  executionId    String?
  conversationId String?
  status         String   @default("pending")
  inputData      String?
  outputData     String?
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([workflowId])
  @@index([conversationId])
}

model CoachingSettings {
  id                String  @id @default(uuid())
  userId            String  @unique
  coachingStyle     String  @default("supportive")
  focusAreas        String  @default("[]")
  weeklyGoal        Int     @default(3)
  reminderEnabled   Boolean @default(true)
  reminderFrequency String  @default("daily")
  user              User    @relation(fields: [userId], references: [id])
}

model Goal {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  specific    String
  measurable  String
  achievable  String
  relevant    String
  timeBound   DateTime
  status      String   @default("active")
  progress    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model JournalEntry {
  id          String   @id @default(uuid())
  userId      String
  prompt      String?
  content     String?
  mood        Int?
  tags        String   @default("[]")
  emotion     String?
  sliderValue Int?
  factors     String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Exercise {
  id              String               @id @default(uuid())
  title           String
  description     String
  category        String
  duration        Int
  difficulty      String               @default("beginner")
  steps           String               @default("[]")
  benefits        String               @default("[]")
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  completions     ExerciseCompletion[]
  recommendations Recommendation[]
}

model ExerciseCompletion {
  id          String   @id @default(uuid())
  userId      String
  exerciseId  String
  notes       String?
  rating      Int?
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise    Exercise @relation(fields: [exerciseId], references: [id])

  @@index([userId])
  @@index([exerciseId])
}

model Report {
  id        String    @id @default(uuid())
  userId    String
  type      String
  period    String
  status    String    @default("pending")
  content   String?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SentimentResult {
  id         String   @id @default(uuid())
  userId     String
  sourceType String
  sourceId   String
  overall    Float
  emotions   String   @default("{}")
  crisis     Boolean  @default(false)
  segments   String   @default("[]")
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sourceId])
}

model UserInsight {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  content   String
  data      String    @default("{}")
  isRead    Boolean   @default(false)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DailyPrompt {
  id          String    @id @default(uuid())
  userId      String
  prompt      String
  type        String
  context     String    @default("{}")
  rating      Int?
  skipped     Boolean   @default(false)
  respondedAt DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Recommendation {
  id         String    @id @default(uuid())
  userId     String
  exerciseId String?
  type       String
  title      String
  reason     String
  score      Float     @default(0.5)
  helpful    Boolean?
  dismissed  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise   Exercise? @relation(fields: [exerciseId], references: [id])

  @@index([userId])
}

model AiUsage {
  id         String   @id @default(uuid())
  userId     String
  service    String
  tokensUsed Int      @default(0)
  costEur    Float    @default(0)
  responseMs Int      @default(0)
  cached     Boolean  @default(false)
  error      Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}
