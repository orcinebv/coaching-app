generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  password            String
  name                String
  role                String               @default("user")
  avatar              String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  conversations       Conversation[]
  checkIns            CheckIn[]
  settings            Settings?
  sessions            Session[]
  coachingSettings    CoachingSettings?
  goals               Goal[]
  journalEntries      JournalEntry[]
  exerciseCompletions ExerciseCompletion[]
  reports             Report[]
}

model Conversation {
  id        String    @id @default(uuid())
  title     String
  userId    String
  status    String    @default("active")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id])
  messages  Message[]
}

model Message {
  id             String       @id @default(uuid())
  content        String
  role           String
  conversationId String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model CheckIn {
  id        String   @id @default(uuid())
  userId    String
  mood      Int
  energy    Int
  notes     String?
  goals     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Settings {
  id            String  @id @default(uuid())
  userId        String  @unique
  notifications Boolean @default(true)
  theme         String  @default("light")
  language      String  @default("nl")
  checkInTime   String  @default("09:00")
  user          User    @relation(fields: [userId], references: [id])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([token])
}

model N8nData {
  id             String   @id @default(uuid())
  workflowId     String
  executionId    String?
  conversationId String?
  status         String   @default("pending")
  inputData      String?
  outputData     String?
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([workflowId])
  @@index([conversationId])
}

model CoachingSettings {
  id                String  @id @default(uuid())
  userId            String  @unique
  coachingStyle     String  @default("supportive")
  focusAreas        String  @default("[]")
  weeklyGoal        Int     @default(3)
  reminderEnabled   Boolean @default(true)
  reminderFrequency String  @default("daily")
  user              User    @relation(fields: [userId], references: [id])
}

model Goal {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  specific    String
  measurable  String
  achievable  String
  relevant    String
  timeBound   DateTime
  status      String   @default("active")
  progress    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model JournalEntry {
  id        String   @id @default(uuid())
  userId    String
  prompt    String?
  content   String
  mood      Int?
  tags      String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Exercise {
  id          String              @id @default(uuid())
  title       String
  description String
  category    String
  duration    Int
  difficulty  String              @default("beginner")
  steps       String              @default("[]")
  benefits    String              @default("[]")
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  completions ExerciseCompletion[]
}

model ExerciseCompletion {
  id          String   @id @default(uuid())
  userId      String
  exerciseId  String
  notes       String?
  rating      Int?
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise    Exercise @relation(fields: [exerciseId], references: [id])

  @@index([userId])
  @@index([exerciseId])
}

model Report {
  id        String    @id @default(uuid())
  userId    String
  type      String
  period    String
  status    String    @default("pending")
  content   String?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
