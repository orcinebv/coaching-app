# ============================================================
# COACHING APP — OMGEVINGSVARIABELEN
# Kopieer dit bestand naar .env en vul alle waarden in.
# .env wordt nooit gecommit (staat in .gitignore).
# ============================================================

# ── Database ────────────────────────────────────────────────
POSTGRES_DB=coaching
POSTGRES_USER=coaching
POSTGRES_PASSWORD=verander-dit-wachtwoord
POSTGRES_PORT=5432

# ── Backend ─────────────────────────────────────────────────
# Genereer een veilige JWT secret: openssl rand -hex 64
JWT_SECRET=verander-dit-naar-een-lange-willekeurige-string
PORT=3000
FRONTEND_URL=http://localhost:4200
APP_URL=http://localhost:4200

# ── OpenAI ──────────────────────────────────────────────────
# Vereist voor de AI coach. Haal je key op via:
# https://platform.openai.com/api-keys
# Wordt automatisch als n8n credential "OpenAI API" ingeladen.
OPENAI_API_KEY=sk-jouw-openai-api-key

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── n8n ─────────────────────────────────────────────────────
N8N_USER=jouw-email@voorbeeld.com
N8N_PASSWORD=verander-dit-wachtwoord
N8N_HOST=localhost
N8N_WEBHOOK_URL=http://n8n:5678
N8N_COACHING_CHAT_WEBHOOK=http://n8n:5678/webhook/coaching-chat
N8N_METRICS=true
N8N_LOG_LEVEL=info

# ── Monitoring ──────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=verander-dit-wachtwoord

# ── SMTP (email notificaties — optioneel) ───────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Frontend ────────────────────────────────────────────────
API_URL=http://localhost:3000
WS_URL=http://localhost:3000
