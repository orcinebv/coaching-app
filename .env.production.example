# GitHub Container Registry — gebruik je GitHub username (lowercase!)
GITHUB_REPOSITORY_OWNER=your-github-username

# PostgreSQL
POSTGRES_DB=coaching_db
POSTGRES_USER=coaching
POSTGRES_PASSWORD=CHANGE_ME

# JWT — genereer met: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_64

# Frontend URL (VPS IP of domein)
FRONTEND_URL=http://YOUR_VPS_IP
VPS_IP=YOUR_VPS_IP

# OpenAI
OPENAI_API_KEY=sk-CHANGE_ME

# n8n
N8N_USER=admin@example.com
N8N_PASSWORD=CHANGE_ME
N8N_HOST=YOUR_VPS_IP
N8N_WEBHOOK_URL=http://YOUR_VPS_IP/n8n
